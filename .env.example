TANG_AGENT_ENV=development

TANG_AGENT_DATA_DIR=./data
TANG_AGENT_LOG_DIR=./logs
TANG_AGENT_WORKSPACE_ROOT=~/ai-workspace

TANG_AGENT_LOG_LEVEL=INFO

# Main language model
TANG_AGENT_MODEL_PROVIDER=deepseek
TANG_AGENT_MODEL_NAME=deepseek-chat
TANG_AGENT_MODEL_API_KEY=
TANG_AGENT_MODEL_BASE_URL=
TANG_AGENT_MODEL_TEMPERATURE=0.2
TANG_AGENT_MODEL_MAX_TOKENS=8192
TANG_AGENT_MODEL_TIMEOUT=60
TANG_AGENT_MODEL_MAX_RETRIES=2