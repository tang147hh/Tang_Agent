TANG_AGENT_ENV=development

TANG_AGENT_DATA_DIR=./data
TANG_AGENT_LOG_DIR=./logs
TANG_AGENT_WORKSPACE_ROOT=~/ai-workspace

TANG_AGENT_LOG_LEVEL=INFO

# Main language model
TANG_AGENT_MODEL_PROVIDER=deepseek
TANG_AGENT_MODEL_NAME=deepseek-v4-pro
TANG_AGENT_MODEL_API_KEY=
TANG_AGENT_MODEL_BASE_URL=https://api.deepseek.com
TANG_AGENT_MODEL_TEMPERATURE=0.2
TANG_AGENT_MODEL_MAX_TOKENS=8192
TANG_AGENT_MODEL_TIMEOUT=60
TANG_AGENT_MODEL_MAX_RETRIES=2

# Run budgets. All values must be greater than zero.
TANG_AGENT_QA_MAX_MODEL_CALLS=3
TANG_AGENT_QA_MAX_TOOL_CALLS=4
TANG_AGENT_QA_MAX_FIRST_OUTPUT_SECONDS=12
TANG_AGENT_QA_MAX_SECONDS=45
TANG_AGENT_QA_MAX_IDENTICAL_TOOL_CALLS=2

TANG_AGENT_PLANNING_MAX_MODEL_CALLS=5
TANG_AGENT_PLANNING_MAX_TOOL_CALLS=10
TANG_AGENT_PLANNING_MAX_FIRST_OUTPUT_SECONDS=20
TANG_AGENT_PLANNING_MAX_SECONDS=120
TANG_AGENT_PLANNING_MAX_IDENTICAL_TOOL_CALLS=2

TANG_AGENT_ANALYSIS_MAX_MODEL_CALLS=8
TANG_AGENT_ANALYSIS_MAX_TOOL_CALLS=20
TANG_AGENT_ANALYSIS_MAX_FIRST_OUTPUT_SECONDS=25
TANG_AGENT_ANALYSIS_MAX_SECONDS=180
TANG_AGENT_ANALYSIS_MAX_IDENTICAL_TOOL_CALLS=2

TANG_AGENT_CODING_MAX_MODEL_CALLS=16
TANG_AGENT_CODING_MAX_TOOL_CALLS=40
TANG_AGENT_CODING_MAX_FIRST_OUTPUT_SECONDS=30
TANG_AGENT_CODING_MAX_SECONDS=480
TANG_AGENT_CODING_MAX_IDENTICAL_TOOL_CALLS=2

# Restrict LangGraph checkpoint deserialization
LANGGRAPH_STRICT_MSGPACK=true
