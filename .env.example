TANG_AGENT_ENV=development

TANG_AGENT_DATA_DIR=./data
TANG_AGENT_LOG_DIR=./logs
TANG_AGENT_WORKSPACE_ROOT=~/ai-workspace

TANG_AGENT_LOG_LEVEL=INFO

# Main language model
TANG_AGENT_MODEL_PROVIDER=deepseek
TANG_AGENT_MODEL_NAME=deepseek-v4-pro
TANG_AGENT_MODEL_API_KEY=
TANG_AGENT_MODEL_BASE_URL=https://api.deepseek.com
TANG_AGENT_MODEL_TEMPERATURE=0.2
TANG_AGENT_MODEL_MAX_TOKENS=8192
TANG_AGENT_MODEL_TIMEOUT=60
TANG_AGENT_MODEL_MAX_RETRIES=2

# Read-only structured web search. Disabled is the safe default.
# zhipu is a fixed adapter; missing SDK/key does not prevent API startup.
TANG_AGENT_WEB_SEARCH_PROVIDER=disabled
ZHIPU_API_KEY=
TANG_AGENT_WEB_SEARCH_CACHE_TTL_SECONDS=600
TANG_AGENT_WEB_SEARCH_EMPTY_CACHE_TTL_SECONDS=60
TANG_AGENT_WEB_SEARCH_CACHE_MAX_ENTRIES=128

# Safe local Git review diff budgets. All values must be greater than zero.
TANG_AGENT_REVIEW_DIFF_MAX_FILES=50
TANG_AGENT_REVIEW_DIFF_MAX_FILE_PATCH_CHARS=40000
TANG_AGENT_REVIEW_DIFF_MAX_FILE_CHANGED_LINES=800
TANG_AGENT_REVIEW_DIFF_MAX_TOTAL_PATCH_CHARS=200000
TANG_AGENT_REVIEW_DIFF_MAX_TOTAL_CHANGED_LINES=3000
TANG_AGENT_REVIEW_GIT_TIMEOUT=30

# GitHub Review publication. Disabled by default because publish is an external write.
# gh stays on the host and is never installed in or exposed to the Agent Runtime.
TANG_AGENT_GITHUB_REVIEW_PUBLISH_ENABLED=false
TANG_AGENT_GITHUB_CLI_TIMEOUT=20
TANG_AGENT_GITHUB_PUBLICATION_TTL_SECONDS=900
TANG_AGENT_GITHUB_REVIEW_MAX_INLINE_COMMENTS=50
TANG_AGENT_GITHUB_REVIEW_MAX_COMMENT_CHARS=8000
TANG_AGENT_GITHUB_REVIEW_MAX_SUMMARY_CHARS=20000

# Run budgets. All values must be greater than zero.
TANG_AGENT_QA_MAX_MODEL_CALLS=3
TANG_AGENT_QA_MAX_TOOL_CALLS=4
TANG_AGENT_QA_MAX_FIRST_OUTPUT_SECONDS=12
TANG_AGENT_QA_MAX_SECONDS=45
TANG_AGENT_QA_MAX_IDENTICAL_TOOL_CALLS=2
TANG_AGENT_QA_NETWORK_MAX_SEARCHES=2
TANG_AGENT_QA_NETWORK_MAX_RESULTS_PER_SEARCH=5
TANG_AGENT_QA_NETWORK_REQUEST_TIMEOUT_SECONDS=15
TANG_AGENT_QA_NETWORK_MAX_RESULT_CHARS_PER_SEARCH=6000
TANG_AGENT_QA_NETWORK_MAX_TOTAL_RESULT_CHARS=12000
TANG_AGENT_QA_NETWORK_MAX_BYTES_RECEIVED=1048576

TANG_AGENT_PLANNING_MAX_MODEL_CALLS=5
TANG_AGENT_PLANNING_MAX_TOOL_CALLS=10
TANG_AGENT_PLANNING_MAX_FIRST_OUTPUT_SECONDS=20
TANG_AGENT_PLANNING_MAX_SECONDS=120
TANG_AGENT_PLANNING_MAX_IDENTICAL_TOOL_CALLS=2
TANG_AGENT_PLANNING_NETWORK_MAX_SEARCHES=3
TANG_AGENT_PLANNING_NETWORK_MAX_RESULTS_PER_SEARCH=5
TANG_AGENT_PLANNING_NETWORK_REQUEST_TIMEOUT_SECONDS=15
TANG_AGENT_PLANNING_NETWORK_MAX_RESULT_CHARS_PER_SEARCH=8000
TANG_AGENT_PLANNING_NETWORK_MAX_TOTAL_RESULT_CHARS=20000
TANG_AGENT_PLANNING_NETWORK_MAX_BYTES_RECEIVED=2097152

TANG_AGENT_ANALYSIS_MAX_MODEL_CALLS=8
TANG_AGENT_ANALYSIS_MAX_TOOL_CALLS=20
TANG_AGENT_ANALYSIS_MAX_FIRST_OUTPUT_SECONDS=25
TANG_AGENT_ANALYSIS_MAX_SECONDS=180
TANG_AGENT_ANALYSIS_MAX_IDENTICAL_TOOL_CALLS=2
TANG_AGENT_ANALYSIS_NETWORK_MAX_SEARCHES=4
TANG_AGENT_ANALYSIS_NETWORK_MAX_RESULTS_PER_SEARCH=5
TANG_AGENT_ANALYSIS_NETWORK_REQUEST_TIMEOUT_SECONDS=15
TANG_AGENT_ANALYSIS_NETWORK_MAX_RESULT_CHARS_PER_SEARCH=8000
TANG_AGENT_ANALYSIS_NETWORK_MAX_TOTAL_RESULT_CHARS=24000
TANG_AGENT_ANALYSIS_NETWORK_MAX_BYTES_RECEIVED=2097152

TANG_AGENT_CODING_MAX_MODEL_CALLS=16
TANG_AGENT_CODING_MAX_TOOL_CALLS=40
TANG_AGENT_CODING_MAX_FIRST_OUTPUT_SECONDS=30
TANG_AGENT_CODING_MAX_SECONDS=480
TANG_AGENT_CODING_MAX_IDENTICAL_TOOL_CALLS=2
TANG_AGENT_CODING_NETWORK_MAX_SEARCHES=4
TANG_AGENT_CODING_NETWORK_MAX_RESULTS_PER_SEARCH=5
TANG_AGENT_CODING_NETWORK_REQUEST_TIMEOUT_SECONDS=15
TANG_AGENT_CODING_NETWORK_MAX_RESULT_CHARS_PER_SEARCH=8000
TANG_AGENT_CODING_NETWORK_MAX_TOTAL_RESULT_CHARS=24000
TANG_AGENT_CODING_NETWORK_MAX_BYTES_RECEIVED=2097152

# Restrict LangGraph checkpoint deserialization
LANGGRAPH_STRICT_MSGPACK=true
